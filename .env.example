# ===== Yandex Webmaster (обязательно) =====
# Токен: oauth.yandex.ru (создать приложение с доступом к Вебмастеру) или Device Flow (swarm/yandex_token.py)
YANDEX_OAUTH_TOKEN=
YANDEX_USER_ID=

# ===== Google Search Console (рекомендуется: service account — бессрочный) =====
# console.cloud.google.com → создать service account → JSON-ключ сюда, email аккаунта
# добавить пользователем в Search Console ваших ресурсов
GSC_SERVICE_ACCOUNT_FILE=./credentials/gsc.json

# ===== Опционально =====
BING_API_KEY=
TELEGRAM_SEO_BOT_TOKEN=
TELEGRAM_SEO_CHAT_ID=
GITHUB_TOKEN=
# IndexNow: ключ на сайт (файл ключа должен лежать в корне сайта)
# INDEXNOW_KEY_MYSITE=
